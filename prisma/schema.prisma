generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int             @id @default(autoincrement())
  name            String
  email           String          @unique
  password        String
  role            String          @default("PATIENT")
  allergies       String?
  phone           String?
  dob             DateTime?
  gender          String?
  bloodGroup      String?
  address         String?
  city            String?
  state           String?
  emergencyName   String?
  emergencyPhone  String?
  photoUrl        String?
  walletAddress   String?         @unique
  walletNonce     String?
  createdAt       DateTime        @default(now())
  donations       Donation[]
  records         PatientRecord[] @relation("PatientRecords")
  createdRecords  PatientRecord[] @relation("CreatedRecords")
}

model PatientRecord {
  id             Int      @id @default(autoincrement())
  patientId      Int
  createdById    Int?
  department     String
  visitType      String
  symptoms       String
  diagnosis      String
  prescription   String
  severity       String
  followUp       String
  notes          String?
  blockchainHash String?
  createdAt      DateTime @default(now())
  patient        User     @relation("PatientRecords", fields: [patientId], references: [id])
  createdBy      User?    @relation("CreatedRecords", fields: [createdById], references: [id])
}

model Donation {
  id              Int       @id @default(autoincrement())
  type            String
  bloodGroup      String?
  status          String
  collectedAt     DateTime
  expiryDate      DateTime?
  currentLocation String
  patientId       Int?
  createdAt       DateTime  @default(now())
  patient         User?     @relation(fields: [patientId], references: [id])
}
